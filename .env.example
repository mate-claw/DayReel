# AWS / S3
AWS_ACCESS_KEY=xxx
AWS_SECRET_KEY=xxx
AWS_REGION=us-east-2
S3_BUCKET=your-bucket

# Shotstack direct render, no template_id needed
SHOTSTACK_KEY=your-shotstack-key
SHOTSTACK_BASE_URL=https://api.shotstack.io/v1

# Qwen / DashScope OpenAI-compatible mode
QWEN_API_KEY=skxxxxx
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_VL_MODEL=qwen-vl-plus
QWEN_TEXT_MODEL=qwen-plus
MOCK_QWEN=false
QWEN_TIMEOUT_SECONDS=35
QWEN_MAX_IMAGES=6

# Template JSON path
TEMPLATE_JSON_PATH=template/shotstack_edit.json

# Chinese font fix
FORCE_CJK_FONT=true
CUSTOM_FONT_URL=https://github.com/notofonts/noto-cjk/raw/main/Sans/Variable/OTF/NotoSansCJKsc-VF.otf
CUSTOM_FONT_FAMILY=NotoSansCJKsc-VF

# Style overrides
FONT_COLOR=#000000
SHAPE_COLOR=#ffffff
BACKGROUND_COLOR_2=#ffffff

# Fallback text
TEST_TITLE=今日高光瞬间
TEST_SUBTITLE=AI 自动生成的视频回忆
TEST_DURATION=10
TEST_TRIM=0
